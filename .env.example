QDRANT_URL=https://YOUR-CLUSTER.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=PASTE_YOUR_QDRANT_API_KEY_HERE
QDRANT_COLLECTION=posco_holdings_report_2026_03_10
#PDF_PATH=[POSCO홀딩스]임원ㆍ주요주주특정증권등소유상황보고서(2026.03.10).pdf
# 여러 PDF를 한 번에 인덱싱할 때는 PDF_PATH 대신 PDF_PATHS 사용 (쉼표·세미콜론·줄바꿈 구분)
PDF_PATHS=POSCO홀딩스_주식 소각 결정_(2026.02.19)주식 소각 결정.pdf, 병합된 테이블 테스트 샘플.pdf
# USE_RERANKER=0  # basic_rag.py CLI: 리랭커 끄고 벡터 검색만 (기본 1)
# USE_HYBRID=0     # fastembed 없이 쓰려면 끄기 (기본 켜짐; 없으면 자동으로 dense만 사용)
# 하이브리드 쓰려면: pip install fastembed (실패 시 Python 3.11 venv 권장)
# MERGE_CROSS_PAGE_TABLES=0  # 연속 페이지 표 병합 끄기 (기본 켜짐; Streamlit 토글과 동일)
